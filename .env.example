# Copy this file to .env and fill in your own values.
# .env is gitignored and must never be committed.

# -----------------------------------------------------------------------------
# RPC endpoints
# -----------------------------------------------------------------------------
# For Stage A sanity tests and all future fork tests. Free options:
#
#   - Ankr (no API key, rate-limited):    https://rpc.ankr.com/eth
#   - Alchemy (signup required):          https://eth-mainnet.g.alchemy.com/v2/YOUR_KEY
#   - Infura (signup required):           https://mainnet.infura.io/v3/YOUR_KEY
#
# Ankr is fastest to set up. Alchemy is more reliable for repeated forks.
MAINNET_RPC_URL=https://rpc.ankr.com/eth

# Sepolia testnet (Stage C, not needed for Stage A or B)
SEPOLIA_RPC_URL=https://rpc.ankr.com/eth_sepolia

# -----------------------------------------------------------------------------
# Etherscan (Stage C)
# -----------------------------------------------------------------------------
# For contract verification after mainnet deployment. Get a free API key at:
# https://etherscan.io/myapikey
ETHERSCAN_API_KEY=

# -----------------------------------------------------------------------------
# Deployment credentials (Stage C only)
# -----------------------------------------------------------------------------
# DO NOT put real private keys here even for testnet.
# Production deployment uses a hardware wallet via foundry's --ledger or
# --trezor flags, NEVER a raw private key in an env file.
#
# For local anvil fork testing, Foundry provides test accounts automatically
# via vm.prank and vm.deal — no private key needed.
DEPLOYER_PRIVATE_KEY=

# -----------------------------------------------------------------------------
# Stage B constants (uncomment and fill in during Stage B)
# -----------------------------------------------------------------------------
# The governance Safe multisig address. Used as the single authorized address
# in AureumAuthorizer. For Stage B fork tests, a Foundry test address is fine.
# For Stage C, use the real mainnet Safe address.
# GOVERNANCE_MULTISIG=0x0000000000000000000000000000000000000000

# Der Bodensee Pool address. Stage B uses a placeholder; Stage C uses the real
# address after der Bodensee Pool is deployed.
# DER_BODENSEE_POOL=0x000000000000000000000000000000000000dEaD
